# Docker Compose environment — sourced automatically by docker-compose.yml
# Copy this to .env and fill in your values:  cp .env.example .env

# Database
POSTGRES_DB=open_brain
POSTGRES_USER=brain_user
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5433

# Open WebUI
WEBUI_SECRET_KEY=open-brain-secret

# NVIDIA API (optional — for premium models in Open WebUI)
NVIDIA_API_KEY=

# Ollama models
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
OLLAMA_CLASSIFIER_MODEL=qwen3:8b
OLLAMA_EXTRACTOR_MODEL=qwen3:8b
